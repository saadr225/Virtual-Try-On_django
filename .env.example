ALLOWED_HOSTS=yourdomain.com,localhost
DB_HOST=127.0.0.1
DB_NAME=db_name
DB_PASSWORD=changeme_db_password
DB_PORT=5432
DB_USER=username
DEBUG=False
GOOGLE_GENAI_API_KEY=YOUR_GOOGLE_GENAI_API_KEY
VERTEX_AI_API_KEY=YOUR_VERTEX_AI_API_KEY

# Host URL for generating public URLs (must include trailing slash)
# This is used to generate absolute URLs for uploaded media files
# Examples:
#   Development: http://localhost:8000/
#   Production: https://yourdomain.com/
#   With subdirectory: https://yourdomain.com/server/
HOST_URL=https://yourdomain.com/

# ============================================================================
# Debug Flags - Fine-grained control over debug logging
# ============================================================================
# Enable these flags to get verbose logging for specific components.
# Useful for debugging specific issues without flooding logs with everything.
# Set to "True" to enable, "False" or omit to disable.

# Middleware Logging
DEBUG_LOG_REQUESTS=False           # Log all incoming HTTP requests
DEBUG_LOG_RESPONSES=False          # Log all HTTP responses
DEBUG_LOG_REQUEST_HEADERS=False    # Include headers in request logs
DEBUG_LOG_REQUEST_BODY=False       # Include request body in logs (small requests only)
DEBUG_LOG_QUERY_PARAMS=False       # Include query parameters in logs

# Database Logging
DEBUG_LOG_DATABASE_QUERIES=False   # Log all SQL queries (can be very verbose)

# API Logging
DEBUG_LOG_API_KEY_VALIDATION=False # Log API key validation attempts

# VTON Processing
DEBUG_LOG_VTON_PROCESSING=False    # Log VTON processing details (enabled if DEBUG=True)

# Performance Metrics
DEBUG_LOG_PERFORMANCE_METRICS=False # Log operation performance timings
